# Configuration for the keep-web daemon. See keep-web/README.md.
#
# The vault password is NOT set here. Write it to /etc/keep-web/password
# (mode 0640, owner root:keep-web); the daemon refuses to start until that
# file exists.

KEEP_PASSWORD_FILE=/etc/keep-web/password

# Vault location. systemd StateDirectory= owns /var/lib/keep-web; the vault
# itself must be a path that does not exist yet on first boot, otherwise
# first-run provisioning sees an empty directory instead of a missing one.
KEEP_PATH=/var/lib/keep-web/vault

# Admin SPA served from the package data directory.
KEEP_WEB_UI_DIR=/usr/share/keep-web/ui

# Listen address. Bound to loopback by default: put it behind a reverse proxy
# or a Tor hidden service rather than exposing the admin API directly.
KEEP_WEB_LISTEN=127.0.0.1:8080

# Nostr relays for the NIP-46 bunker connection.
KEEP_BUNKER_RELAY=wss://bucket.coracle.social

# FROST group npub this node co-signs for. Required for co-signing.
#KEEP_FROST_GROUP=

# Signing is fail-closed: requests must be approved in the admin UI unless
# this is set to true.
#KEEP_FROST_AUTO_APPROVE=false

#RUST_LOG=info
